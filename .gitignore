# ── NEVER commit private key material ──────────────────────────────────────
# The local OpenSSL CA private key (POC path) and every client private key.
ca/
client-*/
*-private-key.pem
*.key

# Build artifacts for the central (KMS) CA Lambda
# No zip is committed — code-stack.yml fetches handler.py/kms_ca.py as plain
# source and builds the deployment zip in-memory at deploy time.
central-ca/packaged.yml
central-ca/*.zip
central-ca/ca-certificate.pem
central-ca/lambda/**/__pycache__/
*.pyc

# Local CA bookkeeping
*.srl

# Social media posts (personal drafts, not part of the project)
SOCIAL_MEDIA_POSTS.md
